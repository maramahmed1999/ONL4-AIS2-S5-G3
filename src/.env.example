# Excavator Pipeline - local config overrides
# Copy this file to .env. All fields are optional.

DEFAULT_VIDEO_PATH=
TARGET_FPS=
PREVIEW_ENABLED=
PREVIEW_FRAME_PATH=
PREVIEW_JPEG_QUALITY=
PREVIEW_EVERY_N_PROCESSED_FRAMES=

MODEL_PATH=
DETECTION_IMGSZ=
DETECTION_EVERY_N_PROCESSED_FRAMES=
# Use 0 for the first CUDA GPU. Leave empty/commented for auto/CPU.
# YOLO_DEVICE=0
CONF_THRESHOLD=
IOU_THRESHOLD=
# Top fraction of bbox used as the arm/bucket region.
ARM_REGION_RATIO=
OPTICAL_FLOW_MAX_WIDTH=

# Mean optical-flow magnitude above this value becomes a WORKING signal.
MOTION_MAGNITUDE_THRESHOLD=

# Pixel displacement of bbox centroid that contributes to the WORKING signal.
MOVE_THRESHOLD_PIXELS=

# Consecutive frames needed to confirm a state transition.
FRAMES_TO_CONFIRM=

# Wall-clock seconds before tracks without updates are removed.
STALE_TRACK_TIMEOUT=

KAFKA_BOOTSTRAP_SERVERS=
KAFKA_TOPIC=
KAFKA_CONSUMER_GROUP_ID=
